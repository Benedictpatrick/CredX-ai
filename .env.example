# ============================================================
# Titan-Credit Environment Variables
# Copy to .env and fill in values
# ============================================================

# LLM (Ollama - local open-source)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
VISION_MODEL=llava:13b
EMBEDDING_MODEL=nomic-embed-text

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/titan_credit.db

# Databricks (Production only)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
UNITY_CATALOG_NAME=titan_credit
UNITY_SCHEMA_NAME=credit_engine

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
